{
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=devautomation;Username=devautomation;Password=devautomation"
  },
  "Database": {
    "ApplyMigrations": true
  },
  "Queue": {
    "KafkaBootstrapServers": "kafka:9092",
    "KafkaTopic": "devautomation.agent-jobs",
    "KafkaDlqTopic": "devautomation.agent-jobs.dlq",
    "KafkaConsumerGroupId": "devautomation-api",
    "MaxAttempts": 3
  },
  "Agent": {
    "MaxConcurrentAgents": 2,
    "AgentTimeout": "00:30:00",
    "ClaudeImage": "devautomation-claude:latest",
    "DockerNetwork": "bridge",
    "ExecutionIsolationProfile": "LocalDevelopment",
    "DockerSocketMode": "LocalDockerSocket",
    "AllowLocalDockerSocket": true,
    "AllowLocalDockerSocketInProductionLike": false,
    "GitAuthorName": "DevAutomation Bot",
    "GitAuthorEmail": "devautomation@example.local",
    "ApprovalMcpCommand": "dotnet /app/DevAutomation.ApprovalMcp.dll",
    "GitLabApiBaseUrl": "https://gitlab.com/api/v4",
    "RemoteRepositoryProvider": "GitHub"
  },
  "CodingAgent": {
    "Provider": "ClaudeCode",
    "ClaudeCommand": "claude"
  },
  "Langfuse": {
    "Enabled": false,
    "Host": "",
    "PublicKey": "",
    "SecretKey": ""
  },
  "LiteLLM": {
    "Enabled": false,
    "BaseUrl": "",
    "ApiKey": "",
    "VirtualKey": ""
  },
  "Approval": {
    "ApprovalTimeout": "00:10:00",
    "PollInterval": "00:00:02"
  },
  "Notifier": {
    "Provider": "Slack",
    "PublicBaseUrl": "http://localhost:8080"
  },
  "Slack": {
    "ApiBaseUrl": "https://slack.com/api/"
  },
  "Gmail": {
    "ApiBaseUrl": "https://gmail.googleapis.com/gmail/v1",
    "UserId": "me",
    "SubjectPrefix": "[DevAutomation]"
  },
  "IssueTracker": {
    "Provider": "None"
  },
  "Jira": {
    "IssueType": "Task"
  },
  "Linear": {
    "ApiBaseUrl": "https://api.linear.app/graphql"
  },
  "DocumentTool": {
    "Provider": "None"
  },
  "Notion": {
    "ApiBaseUrl": "https://api.notion.com/v1",
    "NotionVersion": "2022-06-28"
  },
  "Confluence": {},
  "Telemetry": {
    "Enabled": false,
    "ServiceName": "DevAutomation.Api"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
