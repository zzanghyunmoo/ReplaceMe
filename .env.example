# Copy to .env. Never commit real values.
DEVAUTOMATION_Queue__KafkaBootstrapServers=kafka:9092
DEVAUTOMATION_Queue__KafkaTopic=devautomation.agent-jobs

DEVAUTOMATION_Agent__AnthropicApiKey=
DEVAUTOMATION_Agent__GitHubToken=
DEVAUTOMATION_Agent__GitLabToken=
DEVAUTOMATION_Agent__GitLabApiBaseUrl=https://gitlab.com/api/v4
DEVAUTOMATION_Agent__RemoteRepositoryProvider=GitHub
DEVAUTOMATION_Agent__DockerNetwork=devautomation-network
DEVAUTOMATION_Agent__ApprovalMcpCommand=dotnet /app/DevAutomation.ApprovalMcp.dll
DEVAUTOMATION_CodingAgent__Provider=ClaudeCode
DEVAUTOMATION_CodingAgent__ClaudeCommand=claude

# Notifier provider: Slack, Gmail, or None
DEVAUTOMATION_Notifier__Provider=Slack
DEVAUTOMATION_Notifier__PublicBaseUrl=http://localhost:8080
DEVAUTOMATION_Slack__BotToken=
DEVAUTOMATION_Slack__SigningSecret=
DEVAUTOMATION_Slack__ChannelId=
DEVAUTOMATION_Gmail__AccessToken=
DEVAUTOMATION_Gmail__FromAddress=
DEVAUTOMATION_Gmail__ToAddress=

# Issue tracker provider: Jira, Linear, or None
DEVAUTOMATION_IssueTracker__Provider=None
DEVAUTOMATION_Jira__BaseUrl=
DEVAUTOMATION_Jira__Email=
DEVAUTOMATION_Jira__ApiToken=
DEVAUTOMATION_Jira__ProjectKey=
DEVAUTOMATION_Jira__IssueType=Task
DEVAUTOMATION_Linear__ApiKey=
DEVAUTOMATION_Linear__TeamId=

# Document tool provider: Notion, Confluence, or None
DEVAUTOMATION_DocumentTool__Provider=None
DEVAUTOMATION_Notion__ApiToken=
DEVAUTOMATION_Notion__ParentPageId=
DEVAUTOMATION_Confluence__BaseUrl=
DEVAUTOMATION_Confluence__Email=
DEVAUTOMATION_Confluence__ApiToken=
DEVAUTOMATION_Confluence__SpaceKey=
DEVAUTOMATION_Confluence__ParentPageId=
